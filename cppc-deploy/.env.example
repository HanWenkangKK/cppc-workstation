# ============================================
# Docker Compose 环境变量配置
# ============================================

# --- Nacos 配置 ---
NACOS_MODE=standalone
NACOS_JVM_XMS=512m
NACOS_JVM_XMX=512m
NACOS_JVM_XMN=256m

# --- PostgreSQL 配置 ---
POSTGRES_USER=cppcadmin
POSTGRES_PASSWORD=cppcadmin
POSTGRES_DB=cppc_platform
POSTGRES_PORT=5432

# --- Redis 配置 ---
REDIS_PORT=6379

# --- MinIO 配置 ---
MINIO_ROOT_USER=cppcadmin
MINIO_ROOT_PASSWORD=cppcadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
